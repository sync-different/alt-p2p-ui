{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "alt-p2p",
  "version": "0.1.0",
  "identifier": "com.alterante.p2p.ui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "alt-p2p — File Transfer",
        "width": 800,
        "height": 600,
        "resizable": true,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/run-java"
    ],
    "resources": {
      "../../alt-p2p/target/alt-p2p-0.1.0-SNAPSHOT.jar": "alt-p2p.jar",
      "resources/jre/": "jre/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
